{
  "name": "jpg-perfume-backend",
  "version": "1.0.0",
  "description": "Jean Paul Gaultier Perfume E-commerce Backend API",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run",
    "migrate:reset": "knex migrate:rollback --all && knex migrate:latest && knex seed:run"
  },
  "keywords": [
    "ecommerce",
    "perfume",
    "jean-paul-gaultier"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "knex": "^3.2.10",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.21.0"
  }
}
